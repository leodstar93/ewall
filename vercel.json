{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "functions": {
    "api/**/*.ts": {
      "memory": 3009,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/v1/internal/cron/dmv",
      "schedule": "0 15 * * *"
    }
  ]
}
