generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String? // para Credentials
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // RBAC
  roles UserRole[]

  // Documents
  documents                     Document[]
  notifications                 Notification[]
  userProfile                   UserProfile?
  companyProfile                CompanyProfile?
  paymentMethods                PaymentMethod[]
  achVaults                     AchSecureVault[]
  achAuthorizations             AchAuthorization[]     @relation("AchAuthorizationOwner")
  achAuthorizationAcceptances   AchAuthorization[]     @relation("AchAuthorizationAcceptedBy")
  financialAccessAuditsActed    FinancialAccessAudit[] @relation("FinancialAccessAuditActor")
  financialAccessAuditsTargeted FinancialAccessAudit[] @relation("FinancialAccessAuditTarget")
  filingPaymentUsagesActed      FilingPaymentUsage[]   @relation("FilingPaymentUsageActor")
  filingPaymentUsagesTargeted   FilingPaymentUsage[]   @relation("FilingPaymentUsageTarget")
  organizationMemberships       OrganizationMember[]
  eldProviderCredential         EldProviderCredential?

  //IFTA
  trucks                          Truck[]
  iftaReports                     IftaReport[]
  trips                           Trip[]
  fuelPurchases                   FuelPurchase[]
  ucrFilings                      UCRFiling[]
  form2290Filings                 Form2290Filing[]
  dmvRegistrations                DmvRegistration[]
  dmvRenewalCases                 DmvRenewalCase[]              @relation("UserDmvRenewalCases")
  assignedDmvRenewalCases         DmvRenewalCase[]              @relation("StaffAssignedDmvRenewalCases")
  uploadedDmvRenewalCaseDocuments DmvRenewalCaseDocument[]
  dmvRenewalCaseStatusChanges     DmvRenewalCaseStatusHistory[]
  dmvRenewalCaseMessages          DmvRenewalCaseMessage[]

  // Invitations
  invitationsSent    UserInvitation[] @relation("InvitationSentBy")
  invitationAccepted UserInvitation?  @relation("InvitationAcceptedBy")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompanyProfile {
  id                   String         @id @default(cuid())
  userId               String         @unique
  owner                String?
  name                 String?
  legalName            String?
  dbaName              String?
  companyName          String?
  dotNumber            String?
  mcNumber             String?
  ein                  String?
  phone                String?
  businessPhone        String?
  address              String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  state                String?
  zipCode              String?
  mailingAddressRaw    String?
  trucksCount          Int?
  driversCount         Int?
  saferStatus          String?
  saferEntityType      String?
  saferOperatingStatus String?
  saferPowerUnits      Int?
  saferDrivers         Int?
  saferMcs150Mileage   Int?
  saferMileageYear     Int?
  saferLastFetchedAt   DateTime?
  saferAutoFilled      Boolean        @default(false)
  saferNeedsReview     Boolean        @default(false)
  saferRawSnapshot     Json?
  iftaAccessMode       IftaAccessMode @default(CONTACT_ME)
  iftaAccessNote       String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user                   User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  members                OrganizationMember[]
  paymentMethods         PaymentMethod[]
  subscriptions          OrganizationSubscription[]
  subscriptionGrants     SubscriptionGrant[]
  billingCharges         BillingCharge[]
  eldIntegrationAccounts IntegrationAccount[]
  iftaPortalCredentials  IftaPortalCredential[]
  iftaAutomationFilings  IftaFiling[]
  ucrFilings             UCRFiling[]
  form2290Filings        Form2290Filing[]

  @@index([dotNumber])
  @@index([mcNumber])
}

model EldProviderCredential {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  providerName               String
  loginUrl                   String?
  usernameEncrypted          String
  passwordEncrypted          String
  accountIdentifierEncrypted String?
  notesEncrypted             String?
  encryptionVersion          Int
  encryptionKeyId            String
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([providerName])
  @@index([encryptionKeyId, encryptionVersion])
}

model PaymentMethod {
  id                      String   @id @default(cuid())
  userId                  String
  organizationId          String?
  provider                String // stripe | paypal | ach_vault
  type                    String   @default("card") // card | paypal | ach_vault
  providerCustomerId      String?
  providerPaymentMethodId String?
  brand                   String?
  last4                   String?
  expMonth                Int?
  expYear                 Int?
  isDefault               Boolean  @default(false)
  paypalEmail             String?
  label                   String?
  bankName                String?
  holderName              String?
  accountType             String?
  status                  String   @default("active") // active | pending_authorization | inactive | revoked
  secureVaultId           String?  @unique
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization        CompanyProfile?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  secureVault         AchSecureVault?            @relation("AchVaultPaymentMethod", fields: [secureVaultId], references: [id], onDelete: SetNull)
  authorizations      AchAuthorization[]
  financialAudits     FinancialAccessAudit[]
  filingPaymentUsages FilingPaymentUsage[]
  subscriptions       OrganizationSubscription[] @relation("SubscriptionPaymentMethod")
  billingCharges      BillingCharge[]

  @@index([userId])
  @@index([userId, provider])
  @@index([organizationId])
  @@index([organizationId, provider])
  @@index([type, status])
}

model AchSecureVault {
  id                     String   @id @default(cuid())
  userId                 String
  routingNumberEncrypted String
  accountNumberEncrypted String
  routingLast4           String
  encryptionVersion      Int
  encryptionKeyId        String
  checksum               String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation("AchVaultPaymentMethod")

  @@index([userId, createdAt])
  @@index([encryptionKeyId, encryptionVersion])
}

model AchAuthorization {
  id               String   @id @default(cuid())
  userId           String
  paymentMethodId  String
  consentText      String
  consentVersion   String
  acceptedAt       DateTime
  ipAddress        String?
  userAgent        String?
  acceptedByUserId String?
  status           String   @default("active") // active | revoked | superseded
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User          @relation("AchAuthorizationOwner", fields: [userId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  acceptedBy    User?         @relation("AchAuthorizationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, acceptedAt])
  @@index([paymentMethodId, status])
  @@index([consentVersion])
}

model FinancialAccessAudit {
  id              String   @id @default(cuid())
  actorUserId     String
  targetUserId    String?
  paymentMethodId String?
  filingType      String?
  filingId        String?
  action          String
  resourceType    String
  resourceId      String
  reason          String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  actorUser     User           @relation("FinancialAccessAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser    User?          @relation("FinancialAccessAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([paymentMethodId, createdAt])
  @@index([filingType, filingId])
  @@index([action, createdAt])
  @@index([createdAt])
}

model FilingPaymentUsage {
  id                 String    @id @default(cuid())
  filingType         String
  filingId           String
  targetUserId       String
  paymentMethodId    String
  usedByUserId       String
  usageType          String
  portalName         String?
  amount             Decimal?  @db.Decimal(12, 2)
  paymentDate        DateTime?
  confirmationNumber String?
  status             String    @default("draft") // draft | processing | paid | failed | void
  receiptDocumentId  String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  targetUser      User          @relation("FilingPaymentUsageTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  usedBy          User          @relation("FilingPaymentUsageActor", fields: [usedByUserId], references: [id], onDelete: Restrict)
  receiptDocument Document?     @relation("FilingPaymentUsageReceipt", fields: [receiptDocumentId], references: [id], onDelete: SetNull)

  @@index([filingType, filingId, createdAt])
  @@index([paymentMethodId, createdAt])
  @@index([usedByUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([status, createdAt])
}

enum BillingProvider {
  STRIPE
  PAYPAL
  MANUAL
}

enum SubscriptionInterval {
  MONTH
  YEAR
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  PAUSED
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())

  organization CompanyProfile @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model BillingSettings {
  id                     String   @id @default(cuid())
  subscriptionsEnabled   Boolean  @default(false)
  subscriptionsRequired  Boolean  @default(false)
  allowStripe            Boolean  @default(true)
  allowPaypal            Boolean  @default(true)
  allowCoupons           Boolean  @default(true)
  allowGiftSubscriptions Boolean  @default(true)
  defaultGracePeriodDays Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model NewsUpdate {
  id          String    @id @default(cuid())
  eyebrow     String
  title       String
  description String
  cta         String
  href        String?
  imageUrl    String?
  template    String    @default("MIXED")
  gradient    String
  audience    String    @default("ALL")
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  activeFrom  DateTime?
  activeTo    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, audience, sortOrder])
}

model AppModule {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  name                 String
  description          String?
  isActive             Boolean  @default(true)
  requiresSubscription Boolean  @default(false)
  isCore               Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  planModules PlanModule[]
  grants      SubscriptionGrant[]
}

model SubscriptionPlan {
  id              String               @id @default(cuid())
  code            String               @unique
  name            String
  description     String?
  isActive        Boolean              @default(true)
  interval        SubscriptionInterval
  priceCents      Int
  currency        String               @default("USD")
  stripeProductId String?
  stripePriceId   String?
  paypalPlanId    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  modules       PlanModule[]
  subscriptions OrganizationSubscription[]
}

model PlanModule {
  id        String   @id @default(cuid())
  planId    String
  moduleId  String
  createdAt DateTime @default(now())

  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  module AppModule        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleId])
  @@index([moduleId])
}

model OrganizationSubscription {
  id                     String             @id @default(cuid())
  organizationId         String
  planId                 String?
  paymentMethodId        String?
  provider               BillingProvider
  status                 SubscriptionStatus
  externalCustomerId     String?
  externalSubscriptionId String?            @unique
  externalPlanId         String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  gifted                 Boolean            @default(false)
  giftedByUserId         String?
  giftNote               String?
  couponCode             String?
  lastPaymentAttemptAt   DateTime?
  lastPaymentError       String?
  canceledAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization  CompanyProfile    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  paymentMethod PaymentMethod?    @relation("SubscriptionPaymentMethod", fields: [paymentMethodId], references: [id], onDelete: SetNull)
  charges       BillingCharge[]

  @@index([organizationId, status])
  @@index([planId])
  @@index([paymentMethodId])
  @@index([currentPeriodEnd, status])
}

model BillingCharge {
  id                String          @id @default(cuid())
  organizationId    String
  subscriptionId    String
  paymentMethodId   String?
  provider          BillingProvider
  amountCents       Int
  currency          String          @default("USD")
  status            String
  idempotencyKey    String?         @unique
  externalPaymentId String?
  externalOrderId   String?
  failureCode       String?
  failureMessage    String?
  billedForStart    DateTime?
  billedForEnd      DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization  CompanyProfile           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription  OrganizationSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod?           @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([subscriptionId, createdAt])
  @@index([paymentMethodId])
}

model Coupon {
  id                    String    @id @default(cuid())
  code                  String    @unique
  name                  String?
  discountType          String
  percentOff            Float?
  amountOffCents        Int?
  currency              String?
  durationType          String
  durationInMonths      Int?
  maxRedemptions        Int?
  timesRedeemed         Int       @default(0)
  active                Boolean   @default(true)
  stripeCouponId        String?
  stripePromotionCodeId String?
  startsAt              DateTime?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model SubscriptionGrant {
  id             String    @id @default(cuid())
  organizationId String
  moduleId       String
  source         String
  active         Boolean   @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())

  organization CompanyProfile @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module       AppModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([organizationId, active])
  @@index([moduleId, active])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique // "ADMIN", "DOCTOR", "STAFF"
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // "cases:read"
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  fileName    String
  fileUrl     String
  fileSize    Int // in bytes
  fileType    String // mime type
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form2290Schedule1For      Form2290Filing[]          @relation("Form2290Schedule1")
  form2290Links             Form2290Document[]
  paymentUsageReceipts      FilingPaymentUsage[]      @relation("FilingPaymentUsageReceipt")
  dmvRegistrationLinks      DmvRegistrationDocument[]
  dmvRenewalLinks           DmvRenewalDocument[]
  dmvRenewalCaseSourceLinks DmvRenewalCaseDocument[]

  @@index([userId])
  @@index([category])
}

