generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String? // para Credentials
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // RBAC
  roles UserRole[]

  // Documents
  documents Document[]
  notifications Notification[]
  userProfile            UserProfile?
  companyProfile         CompanyProfile?
  paymentMethods         PaymentMethod[]
  organizationMemberships OrganizationMember[]

  //IFTA
  trucks           Truck[]
  iftaReports      IftaReport[]
  trips            Trip[]
  fuelPurchases    FuelPurchase[]
  ucrFilings       UCRFiling[]
  form2290Filings  Form2290Filing[]
  dmvRegistrations DmvRegistration[]
  dmvRenewalCases  DmvRenewalCase[]        @relation("UserDmvRenewalCases")
  assignedDmvRenewalCases DmvRenewalCase[] @relation("StaffAssignedDmvRenewalCases")
  uploadedDmvRenewalCaseDocuments DmvRenewalCaseDocument[]
  dmvRenewalCaseStatusChanges DmvRenewalCaseStatusHistory[]
  dmvRenewalCaseMessages DmvRenewalCaseMessage[]
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompanyProfile {
  id             String        @id @default(cuid())
  userId         String        @unique
  organizationId String?       @unique
  legalName      String?
  dbaName        String?
  companyName    String?
  dotNumber      String?
  mcNumber       String?
  ein            String?
  phone          String?
  businessPhone  String?
  address        String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  zipCode        String?
  mailingAddressRaw String?
  trucksCount    Int?
  driversCount   Int?
  saferStatus    String?
  saferEntityType String?
  saferOperatingStatus String?
  saferPowerUnits Int?
  saferDrivers   Int?
  saferMcs150Mileage Int?
  saferMileageYear Int?
  saferLastFetchedAt DateTime?
  saferAutoFilled Boolean      @default(false)
  saferNeedsReview Boolean     @default(false)
  saferRawSnapshot Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([dotNumber])
  @@index([mcNumber])
}

model PaymentMethod {
  id                      String   @id @default(cuid())
  userId                  String
  organizationId          String?
  provider                String // stripe | paypal
  providerCustomerId      String?
  providerPaymentMethodId String?
  brand                   String?
  last4                   String?
  expMonth                Int?
  expYear                 Int?
  isDefault               Boolean  @default(false)
  paypalEmail             String?
  createdAt               DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  subscriptions OrganizationSubscription[] @relation("SubscriptionPaymentMethod")
  billingCharges BillingCharge[]

  @@index([userId])
  @@index([userId, provider])
  @@index([organizationId])
  @@index([organizationId, provider])
}

enum BillingProvider {
  STRIPE
  PAYPAL
  MANUAL
}

enum SubscriptionInterval {
  MONTH
  YEAR
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  PAUSED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            OrganizationMember[]
  subscriptions      OrganizationSubscription[]
  paymentMethods     PaymentMethod[]
  subscriptionGrants SubscriptionGrant[]
  billingCharges     BillingCharge[]
  companyProfile     CompanyProfile?
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model BillingSettings {
  id                     String   @id @default(cuid())
  subscriptionsEnabled   Boolean  @default(false)
  subscriptionsRequired  Boolean  @default(false)
  allowStripe            Boolean  @default(true)
  allowPaypal            Boolean  @default(true)
  allowCoupons           Boolean  @default(true)
  allowGiftSubscriptions Boolean  @default(true)
  defaultGracePeriodDays Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AppModule {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  name                 String
  description          String?
  isActive             Boolean  @default(true)
  requiresSubscription Boolean  @default(false)
  isCore               Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  planModules PlanModule[]
  grants      SubscriptionGrant[]
}

model SubscriptionPlan {
  id              String               @id @default(cuid())
  code            String               @unique
  name            String
  description     String?
  isActive        Boolean              @default(true)
  interval        SubscriptionInterval
  priceCents      Int
  currency        String               @default("USD")
  stripeProductId String?
  stripePriceId   String?
  paypalPlanId    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  modules       PlanModule[]
  subscriptions OrganizationSubscription[]
}

model PlanModule {
  id        String   @id @default(cuid())
  planId    String
  moduleId  String
  createdAt DateTime @default(now())

  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  module AppModule        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleId])
  @@index([moduleId])
}

model OrganizationSubscription {
  id                     String             @id @default(cuid())
  organizationId         String
  planId                 String?
  paymentMethodId        String?
  provider               BillingProvider
  status                 SubscriptionStatus
  externalCustomerId     String?
  externalSubscriptionId String?            @unique
  externalPlanId         String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  gifted                 Boolean            @default(false)
  giftedByUserId         String?
  giftNote               String?
  couponCode             String?
  lastPaymentAttemptAt   DateTime?
  lastPaymentError       String?
  canceledAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  paymentMethod PaymentMethod?   @relation("SubscriptionPaymentMethod", fields: [paymentMethodId], references: [id], onDelete: SetNull)
  charges       BillingCharge[]

  @@index([organizationId, status])
  @@index([planId])
  @@index([paymentMethodId])
  @@index([currentPeriodEnd, status])
}

model BillingCharge {
  id              String   @id @default(cuid())
  organizationId  String
  subscriptionId  String
  paymentMethodId String?
  provider        BillingProvider
  amountCents     Int
  currency        String   @default("USD")
  status          String
  externalPaymentId String?
  externalOrderId String?
  failureCode     String?
  failureMessage  String?
  billedForStart  DateTime?
  billedForEnd    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription OrganizationSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod?       @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([subscriptionId, createdAt])
  @@index([paymentMethodId])
}

model Coupon {
  id                    String   @id @default(cuid())
  code                  String   @unique
  name                  String?
  discountType          String
  percentOff            Float?
  amountOffCents        Int?
  currency              String?
  durationType          String
  durationInMonths      Int?
  maxRedemptions        Int?
  timesRedeemed         Int      @default(0)
  active                Boolean  @default(true)
  stripeCouponId        String?
  stripePromotionCodeId String?
  startsAt              DateTime?
  expiresAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SubscriptionGrant {
  id             String   @id @default(cuid())
  organizationId String
  moduleId       String
  source         String
  active         Boolean  @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module       AppModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([organizationId, active])
  @@index([moduleId, active])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique // "ADMIN", "DOCTOR", "STAFF"
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // "cases:read"
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  fileName    String
  fileUrl     String
  fileSize    Int // in bytes
  fileType    String // mime type
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  form2290Schedule1For Form2290Filing[]          @relation("Form2290Schedule1")
  form2290Links        Form2290Document[]
  dmvRegistrationLinks DmvRegistrationDocument[]
  dmvRenewalLinks      DmvRenewalDocument[]
  dmvRenewalCaseSourceLinks DmvRenewalCaseDocument[]

  @@index([userId])
  @@index([category])
}

//IFTA SERVICE
enum FuelType {
  DI // Diesel
  GA // Gasoline
}

enum ReportStatus {
  DRAFT
  PENDING_STAFF_REVIEW
  PENDING_TRUCKER_FINALIZATION
  FILED
  AMENDED
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum UCRFilingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CORRECTION_REQUESTED
  RESUBMITTED
  PENDING_PROOF
  APPROVED
  COMPLIANT
  REJECTED
  CANCELLED
}

enum UCREntityType {
  MOTOR_CARRIER
  BROKER
  FREIGHT_FORWARDER
  LEASING_COMPANY
}

enum UCRDocumentType {
  REGISTRATION_PROOF
  PAYMENT_RECEIPT
  SUPPORTING_DOCUMENT
  CORRECTION_ATTACHMENT
  OTHER
}

enum Form2290Status {
  DRAFT
  PENDING_REVIEW
  NEEDS_CORRECTION
  SUBMITTED
  PAID
  COMPLIANT
  EXPIRED
}

enum Form2290PaymentStatus {
  UNPAID
  PENDING
  PAID
  WAIVED
}

enum Form2290DocumentType {
  SUPPORTING_DOC
  SCHEDULE_1
  PAYMENT_PROOF
}

enum TruckVehicleType {
  TRACTOR
  STRAIGHT_TRUCK
  SEMI_TRUCK
  OTHER
}

enum TruckOperationType {
  INTRASTATE
  INTERSTATE
}

enum DmvRegistrationType {
  NEVADA_ONLY
  IRP
}

enum DmvFilingType {
  INITIAL
  RENEWAL
}

enum DmvRegistrationStatus {
  DRAFT
  WAITING_CLIENT_DOCS
  UNDER_REVIEW
  CORRECTION_REQUIRED
  READY_FOR_FILING
  SUBMITTED
  APPROVED
  ACTIVE
  EXPIRED
  REJECTED
  CANCELLED
}

enum DmvRenewalStatus {
  NOT_OPEN
  OPEN
  WAITING_CLIENT_DOCS
  UNDER_REVIEW
  CORRECTION_REQUIRED
  READY_FOR_FILING
  SUBMITTED
  APPROVED
  COMPLETED
  REJECTED
  OVERDUE
}

enum DmvRenewalCaseStatus {
  SUBMITTED
  IN_REVIEW
  NEEDS_CLIENT_ACTION
  PENDING_CLIENT_APPROVAL
  CHANGES_REQUESTED
  APPROVED
  COMPLETED
  CANCELLED
}

enum DmvRenewalCaseDocumentKind {
  CLIENT_INITIAL_UPLOAD
  CLIENT_RESPONSE_UPLOAD
  STAFF_RETURN_DOCUMENT
  STAFF_INTERNAL_DOCUMENT
}

enum DmvRenewalCaseMessageAudience {
  INTERNAL
  CLIENT_VISIBLE
}

enum DmvRequirementStatus {
  MISSING
  UPLOADED
  APPROVED
  REJECTED
  WAIVED
}

enum DmvDocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DmvMileageSource {
  MANUAL
  IMPORT
  ELD
  PRIOR_JURISDICTION
}

enum DmvActorType {
  SYSTEM
  CLIENT
  STAFF
  ADMIN
}

enum NotificationCategory {
  SYSTEM
  DMV
  IFTA
  UCR
  FORM2290
  DOCUMENTS
  ACCOUNT
}

enum NotificationLevel {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model Truck {
  id             String             @id @default(cuid())
  unitNumber     String
  nickname       String?
  plateNumber    String?
  statePlate     String?
  vin            String?            @unique
  make           String?
  model          String?
  year           Int?
  grossWeight    Int?
  axleCount      Int?
  vehicleType    TruckVehicleType?
  operationType  TruckOperationType @default(INTRASTATE)
  isInterstate   Boolean            @default(false)
  isActive       Boolean            @default(true)
  notes          String?
  is2290Eligible Boolean            @default(false)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  trips            Trip[]
  fuelPurchases    FuelPurchase[]
  iftaReports      IftaReport[]
  form2290Filings  Form2290Filing[]
  dmvRegistrations DmvRegistration[]
  dmvRenewalCases  DmvRenewalCase[]

  @@index([userId])
  @@index([vin])
}

model Jurisdiction {
  id           String   @id @default(cuid())
  code         String   @unique // NV, CA, AZ
  name         String   @unique // Nevada, California
  countryCode  String?
  isIftaMember Boolean  @default(true)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  taxRates                     IftaTaxRate[]
  tripMiles                    TripMileage[]
  fuelPurchases                FuelPurchase[]
  reportLines                  IftaReportLine[]
  dmvRegistrationJurisdictions DmvRegistrationJurisdiction[]
}

model IftaTaxRate {
  id             String       @id @default(cuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  year     Int
  quarter  Quarter
  fuelType FuelType
  taxRate  Decimal  @db.Decimal(10, 4) // ej 1.0230

  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  source           String?
  sourceQuarterKey String?
  sourceFileUrl    String?
  importedAt       DateTime?
  importedById     String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([jurisdictionId, year, quarter, fuelType])
  @@index([year, quarter])
}

model IftaTaxRateImportRun {
  id           String   @id @default(cuid())
  year         Int
  quarter      Quarter
  sourceType   String
  sourceUrl    String?
  totalRows    Int      @default(0)
  insertedRows Int      @default(0)
  updatedRows  Int      @default(0)
  skippedRows  Int      @default(0)
  status       String
  message      String?
  executedAt   DateTime @default(now())
  executedById String?

  @@index([year, quarter, executedAt])
}

model IftaReport {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  truckId String?
  truck   Truck?  @relation(fields: [truckId], references: [id], onDelete: SetNull)

  year     Int
  quarter  Quarter
  fuelType FuelType     @default(DI)
  status   ReportStatus @default(DRAFT)

  totalMiles   Decimal @default(0) @db.Decimal(12, 2)
  totalGallons Decimal @default(0) @db.Decimal(12, 2)
  averageMpg   Decimal @default(0) @db.Decimal(10, 2)
  totalTaxDue  Decimal @default(0) @db.Decimal(12, 2)

  filedAt              DateTime?
  submittedForReviewAt DateTime?
  staffReviewedAt      DateTime?
  notes                String?
  reviewNotes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines         IftaReportLine[]
  trips         Trip[]
  fuelPurchases FuelPurchase[]

  @@unique([userId, truckId, year, quarter, fuelType])
  @@index([userId, year, quarter])
}

model IftaReportLine {
  id       String     @id @default(cuid())
  reportId String
  report   IftaReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)

  fuelType FuelType @default(DI)
  taxRate  Decimal  @db.Decimal(10, 4)

  miles       Decimal @default(0) @db.Decimal(12, 2) // input manual
  paidGallons Decimal @default(0) @db.Decimal(12, 2) // input manual

  taxableMiles      Decimal @default(0) @db.Decimal(12, 2) // calculado
  taxableGallons    Decimal @default(0) @db.Decimal(12, 2) // calculado
  netTaxableGallons Decimal @default(0) @db.Decimal(12, 2) // calculado
  taxDue            Decimal @default(0) @db.Decimal(12, 2) // calculado

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reportId, jurisdictionId, fuelType])
}

model Trip {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  truckId String?
  truck   Truck?  @relation(fields: [truckId], references: [id], onDelete: SetNull)

  reportId String?
  report   IftaReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  tripDate    DateTime
  origin      String?
  destination String?
  totalMiles  Decimal? @db.Decimal(12, 2)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mileages TripMileage[]

  @@index([userId, tripDate])
  @@index([reportId])
}

model TripMileage {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)

  miles     Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tripId, jurisdictionId])
  @@index([jurisdictionId])
}

model FuelPurchase {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  truckId String?
  truck   Truck?  @relation(fields: [truckId], references: [id], onDelete: SetNull)

  reportId String?
  report   IftaReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)

  purchaseDate   DateTime
  fuelType       FuelType @default(DI)
  gallons        Decimal  @db.Decimal(12, 2)
  pricePerGallon Decimal? @db.Decimal(10, 4)
  totalAmount    Decimal? @db.Decimal(12, 2)
  vendor         String?
  receiptNumber  String?
  receiptUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, purchaseDate])
  @@index([reportId])
  @@index([jurisdictionId])
}

model UCRRateBracket {
  id          String   @id @default(cuid())
  year        Int
  minVehicles Int
  maxVehicles Int
  feeAmount   Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([year, minVehicles, maxVehicles])
  @@index([year, active])
}

model UCRFiling {
  id                    String          @id @default(cuid())
  userId                String
  filingYear            Int
  legalName             String
  usdotNumber           String?
  mcNumber              String?
  fein                  String?
  baseState             String?
  entityType            UCREntityType
  interstateOperation   Boolean         @default(true)
  fleetSize             Int
  bracketLabel          String?
  feeAmount             Decimal         @db.Decimal(10, 2)
  status                UCRFilingStatus @default(DRAFT)
  submittedAt           DateTime?
  reviewStartedAt       DateTime?
  correctionRequestedAt DateTime?
  resubmittedAt         DateTime?
  approvedAt            DateTime?
  compliantAt           DateTime?
  rejectedAt            DateTime?
  cancelledAt           DateTime?
  clientNotes           String?
  staffNotes            String?
  correctionNote        String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents UCRDocument[]

  @@unique([userId, filingYear])
  @@index([userId, filingYear])
  @@index([status])
}

model UCRDocument {
  id          String          @id @default(cuid())
  ucrFilingId String
  name        String
  description String?
  filePath    String
  mimeType    String?
  size        Int?
  type        UCRDocumentType @default(OTHER)
  uploadedBy  String?
  createdAt   DateTime        @default(now())

  filing UCRFiling @relation(fields: [ucrFilingId], references: [id], onDelete: Cascade)

  @@index([ucrFilingId, type])
}

model Form2290Setting {
  id                    String   @id @default(cuid())
  minimumEligibleWeight Int      @default(55000)
  expirationWarningDays Int      @default(30)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Form2290TaxPeriod {
  id             String    @id @default(cuid())
  name           String
  startDate      DateTime
  endDate        DateTime
  filingDeadline DateTime?
  isActive       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  filings Form2290Filing[]

  @@index([startDate, endDate])
  @@index([isActive])
}

model Form2290Filing {
  id                  String                @id @default(cuid())
  userId              String
  truckId             String
  taxPeriodId         String
  status              Form2290Status        @default(DRAFT)
  paymentStatus       Form2290PaymentStatus @default(UNPAID)
  vinSnapshot         String
  unitNumberSnapshot  String?
  grossWeightSnapshot Int?
  firstUsedMonth      Int?
  firstUsedYear       Int?
  amountDue           Decimal?              @db.Decimal(10, 2)
  filedAt             DateTime?
  paidAt              DateTime?
  compliantAt         DateTime?
  expiresAt           DateTime?
  schedule1DocumentId String?
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  truck             Truck             @relation(fields: [truckId], references: [id], onDelete: Restrict)
  taxPeriod         Form2290TaxPeriod @relation(fields: [taxPeriodId], references: [id], onDelete: Restrict)
  schedule1Document Document?         @relation("Form2290Schedule1", fields: [schedule1DocumentId], references: [id])

  corrections  Form2290Correction[]
  documents    Form2290Document[]
  activityLogs Form2290ActivityLog[]

  @@unique([truckId, taxPeriodId])
  @@index([userId])
  @@index([truckId])
  @@index([taxPeriodId])
  @@index([status, paymentStatus])
}

model Form2290Correction {
  id            String    @id @default(cuid())
  filingId      String
  requestedById String
  message       String
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  filing Form2290Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([filingId, resolved])
}

model Form2290Document {
  id         String               @id @default(cuid())
  filingId   String
  documentId String
  type       Form2290DocumentType
  createdAt  DateTime             @default(now())

  filing   Form2290Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)
  document Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([filingId, documentId])
  @@index([filingId])
  @@index([documentId])
}

model Form2290ActivityLog {
  id          String   @id @default(cuid())
  filingId    String
  actorUserId String?
  action      String
  metaJson    Json?
  createdAt   DateTime @default(now())

  filing Form2290Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([filingId, createdAt])
}

model DmvRegistration {
  id                    String                @id @default(cuid())
  userId                String
  truckId               String
  registrationType      DmvRegistrationType
  filingType            DmvFilingType         @default(INITIAL)
  status                DmvRegistrationStatus @default(DRAFT)
  dmvAccountNumber      String?
  fleetNumber           String?
  cabCardNumber         String?
  plateNumber           String?
  jurisdictionBase      String?               @default("NV")
  effectiveDate         DateTime?
  expirationDate        DateTime?
  registrationMonth     Int?
  declaredGrossWeight   Int?
  apportioned           Boolean               @default(false)
  establishedBusinessOk Boolean?
  carrierRelocated      Boolean               @default(false)
  dotNumber             String?
  mcNumber              String?
  fein                  String?
  nevadaAddress         String?
  lastSubmittedAt       DateTime?
  lastApprovedAt        DateTime?
  approvedByUserId      String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  user          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  truck         Truck                         @relation(fields: [truckId], references: [id], onDelete: Cascade)
  renewals      DmvRenewal[]
  jurisdictions DmvRegistrationJurisdiction[]
  requirements  DmvRequirementSnapshot[]
  activities    DmvActivity[]
  documents     DmvRegistrationDocument[]

  @@index([userId])
  @@index([truckId])
  @@index([status])
  @@index([expirationDate])
  @@index([registrationType])
}

model DmvRenewal {
  id               String            @id @default(cuid())
  registrationId   String
  cycleYear        Int
  status           DmvRenewalStatus  @default(NOT_OPEN)
  dueDate          DateTime
  openedAt         DateTime?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  approvedAt       DateTime?
  completedAt      DateTime?
  approvedByUserId String?
  internalNotes    String?
  clientNotes      String?
  correctionReason String?
  mileageSource    DmvMileageSource?
  totalMiles       Int?
  nvMiles          Int?
  mileageDataJson  Json?
  feeEstimateJson  Json?
  resultJson       Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  registration DmvRegistration          @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  requirements DmvRequirementSnapshot[]
  documents    DmvRenewalDocument[]
  activities   DmvActivity[]

  @@unique([registrationId, cycleYear])
  @@index([dueDate])
  @@index([status])
}

model DmvRenewalCase {
  id                 String               @id @default(cuid())
  caseNumber         String               @unique
  userId             String
  truckId            String
  assignedToId       String?
  status             DmvRenewalCaseStatus @default(SUBMITTED)
  state              String?
  note               String?
  clientApprovalNote String?
  internalNote       String?
  submittedAt        DateTime?
  inReviewAt         DateTime?
  sentToClientAt     DateTime?
  clientApprovedAt   DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user       User                  @relation("UserDmvRenewalCases", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo User?                 @relation("StaffAssignedDmvRenewalCases", fields: [assignedToId], references: [id], onDelete: SetNull)
  truck      Truck                 @relation(fields: [truckId], references: [id], onDelete: Cascade)
  documents  DmvRenewalCaseDocument[]
  statusHistory DmvRenewalCaseStatusHistory[]
  messages   DmvRenewalCaseMessage[]

  @@index([userId])
  @@index([truckId])
  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
}

model DmvRegistrationJurisdiction {
  id               String  @id @default(cuid())
  registrationId   String
  jurisdictionId   String?
  jurisdictionCode String
  declaredWeight   Int?
  estimatedMiles   Int?
  actualMiles      Int?

  registration DmvRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  jurisdiction Jurisdiction?   @relation(fields: [jurisdictionId], references: [id], onDelete: SetNull)

  @@unique([registrationId, jurisdictionCode])
  @@index([registrationId])
  @@index([jurisdictionId])
}

model DmvRequirementTemplate {
  id               String               @id @default(cuid())
  code             String               @unique
  name             String
  appliesToType    DmvRegistrationType?
  appliesToRenewal Boolean              @default(true)
  appliesToInitial Boolean              @default(true)
  isRequired       Boolean              @default(true)
  sortOrder        Int                  @default(0)
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([active, sortOrder])
  @@index([appliesToType])
}

model DmvRequirementSnapshot {
  id             String               @id @default(cuid())
  registrationId String
  renewalId      String?
  code           String
  name           String
  isRequired     Boolean
  status         DmvRequirementStatus @default(MISSING)
  note           String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  registration DmvRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  renewal      DmvRenewal?     @relation(fields: [renewalId], references: [id], onDelete: Cascade)

  @@unique([registrationId, renewalId, code])
  @@index([registrationId])
  @@index([renewalId])
  @@index([status])
}

model DmvRegistrationDocument {
  id              String                  @id @default(cuid())
  registrationId  String
  requirementCode String?
  documentId      String
  status          DmvDocumentReviewStatus @default(PENDING)
  rejectionNote   String?
  createdAt       DateTime                @default(now())

  registration DmvRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  document     Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([registrationId, documentId])
  @@index([registrationId])
  @@index([documentId])
  @@index([requirementCode])
}

model DmvRenewalDocument {
  id              String                  @id @default(cuid())
  renewalId       String
  requirementCode String?
  documentId      String
  status          DmvDocumentReviewStatus @default(PENDING)
  rejectionNote   String?
  createdAt       DateTime                @default(now())

  renewal  DmvRenewal @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  document Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([renewalId, documentId])
  @@index([renewalId])
  @@index([documentId])
  @@index([requirementCode])
}

model DmvRenewalCaseDocument {
  id               String                    @id @default(cuid())
  renewalId        String
  uploadedByUserId String
  kind             DmvRenewalCaseDocumentKind
  fileName         String
  fileUrl          String
  fileSize         Int?
  mimeType         String?
  note             String?
  visibleToClient  Boolean                   @default(true)
  sourceDocumentId String?
  createdAt        DateTime                  @default(now())

  renewal        DmvRenewalCase @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  uploadedBy     User           @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  sourceDocument Document?      @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([renewalId])
  @@index([uploadedByUserId])
  @@index([kind])
  @@index([sourceDocumentId])
}

model DmvRenewalCaseStatusHistory {
  id              String               @id @default(cuid())
  renewalId       String
  fromStatus      DmvRenewalCaseStatus?
  toStatus        DmvRenewalCaseStatus
  changedByUserId String
  note            String?
  createdAt       DateTime             @default(now())

  renewal   DmvRenewalCase @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  changedBy User           @relation(fields: [changedByUserId], references: [id], onDelete: Cascade)

  @@index([renewalId])
  @@index([changedByUserId])
  @@index([createdAt])
}

model DmvRenewalCaseMessage {
  id        String                       @id @default(cuid())
  renewalId String
  authorId  String
  audience  DmvRenewalCaseMessageAudience @default(CLIENT_VISIBLE)
  message   String
  createdAt DateTime                     @default(now())

  renewal DmvRenewalCase @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  author  User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([renewalId])
  @@index([authorId])
  @@index([audience])
}

model DmvActivity {
  id             String       @id @default(cuid())
  registrationId String?
  renewalId      String?
  actorUserId    String?
  actorType      DmvActorType
  action         String
  fromStatus     String?
  toStatus       String?
  message        String?
  metadataJson   Json?
  createdAt      DateTime     @default(now())

  registration DmvRegistration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  renewal      DmvRenewal?      @relation(fields: [renewalId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([renewalId])
  @@index([createdAt])
}

model Notification {
  id          String               @id @default(cuid())
  userId      String
  title       String
  message     String
  category    NotificationCategory @default(SYSTEM)
  level       NotificationLevel    @default(INFO)
  href        String?
  actionLabel String?
  readAt      DateTime?
  metadataJson Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([category, createdAt])
}

model DmvFeeRule {
  id               String               @id @default(cuid())
  registrationType DmvRegistrationType?
  jurisdictionCode String?
  vehicleType      TruckVehicleType?
  minWeight        Int?
  maxWeight        Int?
  amount           Decimal              @db.Decimal(10, 2)
  active           Boolean              @default(true)
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([registrationType, active])
  @@index([jurisdictionCode, active])
}

model SandboxScenario {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  moduleKey   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SandboxAuditLog {
  id             String   @id @default(cuid())
  environment    String
  actorUserId    String
  actingAsUserId String?
  actingAsRole   String?
  action         String
  entityType     String?
  entityId       String?
  metadataJson   Json?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
}

model SandboxImpersonationSession {
  id             String   @id @default(cuid())
  actorUserId    String
  actingAsUserId String?
  actingAsRole   String?
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([actorUserId, isActive])
  @@index([actingAsUserId, isActive])
}
