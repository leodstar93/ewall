model Truck {
  id             String             @id @default(cuid())
  unitNumber     String
  nickname       String?
  plateNumber    String?
  statePlate     String?
  vin            String?            @unique
  make           String?
  model          String?
  year           Int?
  grossWeight    Int?
  axleCount      Int?
  vehicleType    TruckVehicleType?
  operationType  TruckOperationType @default(INTRASTATE)
  isInterstate   Boolean            @default(false)
  isActive       Boolean            @default(true)
  notes          String?
  is2290Eligible Boolean            @default(false)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  trips            Trip[]
  fuelPurchases    FuelPurchase[]
  iftaReports      IftaReport[]
  form2290Filings  Form2290Filing[]
