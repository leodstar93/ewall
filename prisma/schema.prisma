generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?   // para Credentials
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // RBAC
  roles         UserRole[]
  
  // Documents
  documents     Document[]

  //IFTA
  trucks        Truck[]
  iftaReports   IftaReport[]
  trips         Trip[]
  fuelPurchases FuelPurchase[]
  ucrFilings    UCRFiling[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String @id @default(cuid())
  name        String @unique // "ADMIN", "DOCTOR", "STAFF"
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique // "cases:read"
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  description String?
  fileName    String
  fileUrl     String
  fileSize    Int      // in bytes
  fileType    String   // mime type
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

//IFTA SERVICE
enum FuelType {
  DI // Diesel
  GA // Gasoline
}

enum ReportStatus {
  DRAFT
  PENDING_STAFF_REVIEW
  PENDING_TRUCKER_FINALIZATION
  FILED
  AMENDED
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum UCRFilingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CORRECTION_REQUESTED
  RESUBMITTED
  PENDING_PROOF
  APPROVED
  COMPLIANT
  REJECTED
  CANCELLED
}

enum UCREntityType {
  MOTOR_CARRIER
  BROKER
  FREIGHT_FORWARDER
  LEASING_COMPANY
}

enum UCRDocumentType {
  REGISTRATION_PROOF
  PAYMENT_RECEIPT
  SUPPORTING_DOCUMENT
  CORRECTION_ATTACHMENT
  OTHER
}

model Truck {
  id           String   @id @default(cuid())
  unitNumber   String
  nickname     String?
  plateNumber  String?
  vin          String?  @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trips        Trip[]
  fuelPurchases FuelPurchase[]
  iftaReports  IftaReport[]

  @@index([userId])
}

model Jurisdiction {
  id          String   @id @default(cuid())
  code        String   @unique // NV, CA, AZ
  name        String   @unique // Nevada, California
  countryCode String?
  isIftaMember Boolean @default(true)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taxRates    IftaTaxRate[]
  tripMiles   TripMileage[]
  fuelPurchases FuelPurchase[]
  reportLines IftaReportLine[]
}

model IftaTaxRate {
  id               String       @id @default(cuid())
  jurisdictionId   String
  jurisdiction     Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  year             Int
  quarter          Quarter
  fuelType         FuelType
  taxRate          Decimal      @db.Decimal(10, 4) // ej 1.0230

  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  source           String?
  sourceQuarterKey String?
  sourceFileUrl    String?
  importedAt       DateTime?
  importedById     String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([jurisdictionId, year, quarter, fuelType])
  @@index([year, quarter])
}

model IftaTaxRateImportRun {
  id            String   @id @default(cuid())
  year          Int
  quarter       Quarter
  sourceType    String
  sourceUrl     String?
  totalRows     Int      @default(0)
  insertedRows  Int      @default(0)
  updatedRows   Int      @default(0)
  skippedRows   Int      @default(0)
  status        String
  message       String?
  executedAt    DateTime @default(now())
  executedById  String?

  @@index([year, quarter, executedAt])
}

model IftaReport {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  truckId           String?
  truck             Truck?        @relation(fields: [truckId], references: [id], onDelete: SetNull)

  year              Int
  quarter           Quarter
  fuelType          FuelType      @default(DI)
  status            ReportStatus  @default(DRAFT)

  totalMiles        Decimal       @default(0) @db.Decimal(12, 2)
  totalGallons      Decimal       @default(0) @db.Decimal(12, 2)
  averageMpg        Decimal       @default(0) @db.Decimal(10, 2)
  totalTaxDue       Decimal       @default(0) @db.Decimal(12, 2)

  filedAt           DateTime?
  submittedForReviewAt DateTime?
  staffReviewedAt   DateTime?
  notes             String?
  reviewNotes       String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  lines             IftaReportLine[]
  trips             Trip[]
  fuelPurchases     FuelPurchase[]

  @@unique([userId, truckId, year, quarter, fuelType])
  @@index([userId, year, quarter])
}

model IftaReportLine {
  id                  String        @id @default(cuid())
  reportId            String
  report              IftaReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)

  jurisdictionId      String
  jurisdiction        Jurisdiction  @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)

  fuelType            FuelType      @default(DI)
  taxRate             Decimal       @db.Decimal(10, 4)

  miles               Decimal       @default(0) @db.Decimal(12, 2)   // input manual
  paidGallons         Decimal       @default(0) @db.Decimal(12, 2)   // input manual

  taxableMiles        Decimal       @default(0) @db.Decimal(12, 2)   // calculado
  taxableGallons      Decimal       @default(0) @db.Decimal(12, 2)   // calculado
  netTaxableGallons   Decimal       @default(0) @db.Decimal(12, 2)   // calculado
  taxDue              Decimal       @default(0) @db.Decimal(12, 2)   // calculado

  sortOrder           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([reportId, jurisdictionId, fuelType])
}

model Trip {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  truckId        String?
  truck          Truck?         @relation(fields: [truckId], references: [id], onDelete: SetNull)

  reportId       String?
  report         IftaReport?    @relation(fields: [reportId], references: [id], onDelete: SetNull)

  tripDate       DateTime
  origin         String?
  destination    String?
  totalMiles     Decimal?       @db.Decimal(12, 2)
  notes          String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  mileages       TripMileage[]

  @@index([userId, tripDate])
  @@index([reportId])
}

model TripMileage {
  id               String        @id @default(cuid())
  tripId           String
  trip             Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)

  jurisdictionId   String
  jurisdiction     Jurisdiction  @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)

  miles            Decimal       @default(0) @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([tripId, jurisdictionId])
  @@index([jurisdictionId])
}

model FuelPurchase {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  truckId          String?
  truck            Truck?        @relation(fields: [truckId], references: [id], onDelete: SetNull)

  reportId         String?
  report           IftaReport?   @relation(fields: [reportId], references: [id], onDelete: SetNull)

  jurisdictionId   String
  jurisdiction     Jurisdiction  @relation(fields: [jurisdictionId], references: [id], onDelete: Restrict)

  purchaseDate     DateTime
  fuelType         FuelType      @default(DI)
  gallons          Decimal       @db.Decimal(12, 2)
  pricePerGallon   Decimal?      @db.Decimal(10, 4)
  totalAmount      Decimal?      @db.Decimal(12, 2)
  vendor           String?
  receiptNumber    String?
  receiptUrl       String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId, purchaseDate])
  @@index([reportId])
  @@index([jurisdictionId])
}

model UCRRateBracket {
  id          String   @id @default(cuid())
  year        Int
  minVehicles Int
  maxVehicles Int
  feeAmount   Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([year, active])
  @@unique([year, minVehicles, maxVehicles])
}

model UCRFiling {
  id                    String           @id @default(cuid())
  userId                String
  filingYear            Int
  legalName             String
  usdotNumber           String?
  mcNumber              String?
  fein                  String?
  baseState             String?
  entityType            UCREntityType
  interstateOperation   Boolean          @default(true)
  fleetSize             Int
  bracketLabel          String?
  feeAmount             Decimal          @db.Decimal(10, 2)
  status                UCRFilingStatus  @default(DRAFT)
  submittedAt           DateTime?
  reviewStartedAt       DateTime?
  correctionRequestedAt DateTime?
  resubmittedAt         DateTime?
  approvedAt            DateTime?
  compliantAt           DateTime?
  rejectedAt            DateTime?
  cancelledAt           DateTime?
  clientNotes           String?
  staffNotes            String?
  correctionNote        String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents UCRDocument[]

  @@index([userId, filingYear])
  @@index([status])
  @@unique([userId, filingYear])
}

model UCRDocument {
  id          String          @id @default(cuid())
  ucrFilingId String
  name        String
  description String?
  filePath    String
  mimeType    String?
  size        Int?
  type        UCRDocumentType @default(OTHER)
  uploadedBy  String?
  createdAt   DateTime        @default(now())

  filing UCRFiling @relation(fields: [ucrFilingId], references: [id], onDelete: Cascade)

  @@index([ucrFilingId, type])
}
