  toStatus    String
  actorUserId String?
  reason      String?
  createdAt   DateTime @default(now())

  filing UCRFiling @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([filingId, createdAt])
}

model Form2290Setting {
  id                            String   @id @default(cuid())
  enabled                       Boolean  @default(true)
  processingMode                Form2290ProcessingMode @default(STAFF_ASSISTED)
  minimumEligibleWeight         Int      @default(55000)
  expirationWarningDays         Int      @default(30)
  serviceFeeCents               Int      @default(0)
  requirePaymentBeforeSubmit    Boolean  @default(true)
  collectIrsTaxEstimate         Boolean  @default(false)
  allowCustomerPaysProvider     Boolean  @default(true)
  allowEwallCollectsAndRemits   Boolean  @default(true)
  requireSchedule1ForCompliance Boolean  @default(true)
  authorizationText             String?  @db.Text
  providerName                  String?
  providerUrl                   String?
  operationalInstructions       String?  @db.Text
  howToProcessClient            String?  @db.Text
  howToProcessStaff             String?  @db.Text
  internalStaffChecklist        String?  @db.Text
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model Form2290TaxPeriod {
  id             String    @id @default(cuid())
  name           String
  startDate      DateTime
  endDate        DateTime
  filingDeadline DateTime?
  isActive       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  filings Form2290Filing[]

  @@index([startDate, endDate])
  @@index([isActive])
}

model Form2290Filing {
  id                        String                  @id @default(cuid())
  userId                    String
  organizationId            String?
  truckId                   String
  taxPeriodId               String
  status                    Form2290Status          @default(DRAFT)
  paymentStatus             Form2290PaymentStatus   @default(UNPAID)
  filingMethod              Form2290FilingMethod    @default(STAFF_ASSISTED_PROVIDER)
  paymentHandling           Form2290PaymentHandling @default(CUSTOMER_PAYS_PROVIDER)
  vinSnapshot               String
  unitNumberSnapshot        String?
  grossWeightSnapshot       Int?
  firstUsedMonth            Int?
  firstUsedYear             Int?
  amountDue                 Decimal?                @db.Decimal(10, 2)
  serviceFeeAmount          Decimal?                @db.Decimal(10, 2)
  paymentReference          String?
  defaultPaymentMethodId    String?
  efileProviderName         String?
  efileProviderUrl          String?
  efileConfirmationNumber   String?
  staffInstructionsSnapshot String?                 @db.Text
  howToProcessClientSnapshot String?                @db.Text
  howToProcessStaffSnapshot  String?                @db.Text
  internalStaffChecklistSnapshot String?            @db.Text
  claimedByUserId           String?
  reviewStartedAt           DateTime?
  readyToFileAt             DateTime?
  paymentReceivedAt         DateTime?
  filedExternallyAt         DateTime?
  filedAt                   DateTime?
  paidAt                    DateTime?
  compliantAt               DateTime?
  cancelledAt               DateTime?
  reopenedAt                DateTime?
  expiresAt                 DateTime?
  schedule1DocumentId       String?
  taxableGrossWeightSnapshot Int?
  loggingVehicle            Boolean?
  suspendedVehicle          Boolean?
  confirmationAcceptedAt    DateTime?
  irsTaxEstimate            Decimal?                @db.Decimal(10, 2)
  notes                     String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      CompanyProfile?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  truck             Truck             @relation(fields: [truckId], references: [id], onDelete: Restrict)
  taxPeriod         Form2290TaxPeriod @relation(fields: [taxPeriodId], references: [id], onDelete: Restrict)
  schedule1Document Document?         @relation("Form2290Schedule1", fields: [schedule1DocumentId], references: [id])

  corrections   Form2290Correction[]
  documents     Form2290Document[]
  activityLogs  Form2290ActivityLog[]
  vehicles      Form2290FilingVehicle[]
  authorization Form2290ClientAuthorization?

  @@unique([truckId, taxPeriodId])
  @@index([userId])
  @@index([organizationId])
  @@index([truckId])
  @@index([taxPeriodId])
  @@index([status, paymentStatus])
  @@index([claimedByUserId, status])
  @@index([defaultPaymentMethodId])
}

model Form2290FilingVehicle {
  id                  String   @id @default(cuid())
  filingId            String
  truckId             String?
  vinSnapshot         String
  unitNumberSnapshot  String?
  grossWeightSnapshot Int?
  isPrimary           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  filing Form2290Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([filingId])
  @@index([truckId])
}

model Form2290ClientAuthorization {
  id                String                      @id @default(cuid())
  filingId          String                      @unique
  status            Form2290AuthorizationStatus @default(UNSIGNED)
  signerName        String?
  signerTitle       String?
  signatureText     String?                     @db.Text
  authorizationText String?                     @db.Text
  signedAt          DateTime?
  signedByUserId    String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  filing Form2290Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([status, signedAt])
}

model Form2290Correction {
  id            String    @id @default(cuid())
  filingId      String
  requestedById String
  message       String
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  filing Form2290Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([filingId, resolved])
}

model Form2290Document {
  id         String               @id @default(cuid())
  filingId   String
  documentId String
  type       Form2290DocumentType
  createdAt  DateTime             @default(now())

  filing   Form2290Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)
  document Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([filingId, documentId])
  @@index([filingId])
  @@index([documentId])
}

model Form2290ActivityLog {
  id          String   @id @default(cuid())
  filingId    String
  actorUserId String?
  action      String
  metaJson    Json?
  createdAt   DateTime @default(now())

  filing Form2290Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([filingId, createdAt])
}

model DmvRegistration {
  id                    String                @id @default(cuid())
  userId                String
  truckId               String
  registrationType      DmvRegistrationType
  filingType            DmvFilingType         @default(INITIAL)
  status                DmvRegistrationStatus @default(DRAFT)
  dmvAccountNumber      String?
  fleetNumber           String?
  cabCardNumber         String?
  plateNumber           String?
  jurisdictionBase      String?               @default("NV")
  effectiveDate         DateTime?
  expirationDate        DateTime?
  registrationMonth     Int?
  declaredGrossWeight   Int?
  apportioned           Boolean               @default(false)
  establishedBusinessOk Boolean?
  carrierRelocated      Boolean               @default(false)
  dotNumber             String?
  mcNumber              String?
  fein                  String?
  nevadaAddress         String?
  lastSubmittedAt       DateTime?
  lastApprovedAt        DateTime?
  approvedByUserId      String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  user          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  truck         Truck                         @relation(fields: [truckId], references: [id], onDelete: Cascade)
  renewals      DmvRenewal[]
  jurisdictions DmvRegistrationJurisdiction[]
  requirements  DmvRequirementSnapshot[]
  activities    DmvActivity[]
  documents     DmvRegistrationDocument[]

  @@index([userId])
  @@index([truckId])
  @@index([status])
  @@index([expirationDate])
  @@index([registrationType])
}

model DmvRenewal {
  id               String            @id @default(cuid())
  registrationId   String
  cycleYear        Int
  status           DmvRenewalStatus  @default(NOT_OPEN)
  dueDate          DateTime
  openedAt         DateTime?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  approvedAt       DateTime?
  completedAt      DateTime?
  approvedByUserId String?
  internalNotes    String?
  clientNotes      String?
  correctionReason String?
  mileageSource    DmvMileageSource?
  totalMiles       Int?
  nvMiles          Int?
  mileageDataJson  Json?
  feeEstimateJson  Json?
  resultJson       Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  registration DmvRegistration          @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  requirements DmvRequirementSnapshot[]
  documents    DmvRenewalDocument[]
  activities   DmvActivity[]

  @@unique([registrationId, cycleYear])
  @@index([dueDate])
  @@index([status])
}

model DmvRenewalCase {
  id                 String               @id @default(cuid())
  caseNumber         String               @unique
  userId             String
  truckId            String
  assignedToId       String?
  status             DmvRenewalCaseStatus @default(SUBMITTED)
  state              String?
  note               String?
  clientApprovalNote String?
  internalNote       String?
  submittedAt        DateTime?
  inReviewAt         DateTime?
  sentToClientAt     DateTime?
  clientApprovedAt   DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user          User                          @relation("UserDmvRenewalCases", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo    User?                         @relation("StaffAssignedDmvRenewalCases", fields: [assignedToId], references: [id], onDelete: SetNull)
  truck         Truck                         @relation(fields: [truckId], references: [id], onDelete: Cascade)
  documents     DmvRenewalCaseDocument[]
  statusHistory DmvRenewalCaseStatusHistory[]
  messages      DmvRenewalCaseMessage[]

  @@index([userId])
  @@index([truckId])
  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
}

model DmvRegistrationJurisdiction {
  id               String  @id @default(cuid())
  registrationId   String
  jurisdictionId   String?
  jurisdictionCode String
  declaredWeight   Int?
  estimatedMiles   Int?
  actualMiles      Int?

  registration DmvRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  jurisdiction Jurisdiction?   @relation(fields: [jurisdictionId], references: [id], onDelete: SetNull)

  @@unique([registrationId, jurisdictionCode])
  @@index([registrationId])
  @@index([jurisdictionId])
}

model DmvRequirementTemplate {
  id               String               @id @default(cuid())
  code             String               @unique
  name             String
  appliesToType    DmvRegistrationType?
  appliesToRenewal Boolean              @default(true)
  appliesToInitial Boolean              @default(true)
  isRequired       Boolean              @default(true)
  sortOrder        Int                  @default(0)
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([active, sortOrder])
  @@index([appliesToType])
}

model DmvRequirementSnapshot {
  id             String               @id @default(cuid())
  registrationId String
  renewalId      String?
  code           String
  name           String
  isRequired     Boolean
  status         DmvRequirementStatus @default(MISSING)
  note           String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  registration DmvRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  renewal      DmvRenewal?     @relation(fields: [renewalId], references: [id], onDelete: Cascade)

  @@unique([registrationId, renewalId, code])
  @@index([registrationId])
  @@index([renewalId])
  @@index([status])
}

model DmvRegistrationDocument {
  id              String                  @id @default(cuid())
  registrationId  String
  requirementCode String?
  documentId      String
  status          DmvDocumentReviewStatus @default(PENDING)
  rejectionNote   String?
  createdAt       DateTime                @default(now())

  registration DmvRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  document     Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([registrationId, documentId])
  @@index([registrationId])
  @@index([documentId])
  @@index([requirementCode])
}

model DmvRenewalDocument {
  id              String                  @id @default(cuid())
  renewalId       String
  requirementCode String?
  documentId      String
  status          DmvDocumentReviewStatus @default(PENDING)
  rejectionNote   String?
  createdAt       DateTime                @default(now())

  renewal  DmvRenewal @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  document Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([renewalId, documentId])
  @@index([renewalId])
  @@index([documentId])
  @@index([requirementCode])
}

model DmvRenewalCaseDocument {
  id               String                     @id @default(cuid())
  renewalId        String
  uploadedByUserId String
  kind             DmvRenewalCaseDocumentKind
  fileName         String
  fileUrl          String
  fileSize         Int?
  mimeType         String?
  note             String?
  visibleToClient  Boolean                    @default(true)
  sourceDocumentId String?
  createdAt        DateTime                   @default(now())

  renewal        DmvRenewalCase @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  uploadedBy     User           @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  sourceDocument Document?      @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([renewalId])
  @@index([uploadedByUserId])
  @@index([kind])
  @@index([sourceDocumentId])
}

model DmvRenewalCaseStatusHistory {
  id              String                @id @default(cuid())
  renewalId       String
  fromStatus      DmvRenewalCaseStatus?
  toStatus        DmvRenewalCaseStatus
  changedByUserId String
  note            String?
  createdAt       DateTime              @default(now())

  renewal   DmvRenewalCase @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  changedBy User           @relation(fields: [changedByUserId], references: [id], onDelete: Cascade)

  @@index([renewalId])
  @@index([changedByUserId])
  @@index([createdAt])
}

model DmvRenewalCaseMessage {
  id        String                        @id @default(cuid())
  renewalId String
  authorId  String
  audience  DmvRenewalCaseMessageAudience @default(CLIENT_VISIBLE)
  message   String
  createdAt DateTime                      @default(now())

  renewal DmvRenewalCase @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  author  User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([renewalId])
  @@index([authorId])
  @@index([audience])
}

model DmvActivity {
  id             String       @id @default(cuid())
  registrationId String?
  renewalId      String?
  actorUserId    String?
  actorType      DmvActorType
  action         String
  fromStatus     String?
  toStatus       String?
  message        String?
  metadataJson   Json?
  createdAt      DateTime     @default(now())

  registration DmvRegistration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  renewal      DmvRenewal?      @relation(fields: [renewalId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([renewalId])
  @@index([createdAt])
}

model Notification {
  id           String               @id @default(cuid())
  userId       String
  title        String
  message      String
  category     NotificationCategory @default(SYSTEM)
  level        NotificationLevel    @default(INFO)
  href         String?
  actionLabel  String?
  readAt       DateTime?
  metadataJson Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([category, createdAt])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  subject     String
  bodyText    String   @db.Text
  variables   Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

model DmvFeeRule {
  id               String               @id @default(cuid())
  registrationType DmvRegistrationType?
  jurisdictionCode String?
  vehicleType      TruckVehicleType?
  minWeight        Int?
  maxWeight        Int?
  amount           Decimal              @db.Decimal(10, 2)
  active           Boolean              @default(true)
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([registrationType, active])
  @@index([jurisdictionCode, active])
}

model SandboxScenario {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  moduleKey   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SandboxAuditLog {
  id             String   @id @default(cuid())
  environment    String
  actorUserId    String
  actingAsUserId String?
  actingAsRole   String?
  action         String
  entityType     String?
  entityId       String?
  metadataJson   Json?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
}

model SandboxImpersonationSession {
  id             String    @id @default(cuid())
  actorUserId    String
  actingAsUserId String?
  actingAsRole   String?
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([actorUserId, isActive])
  @@index([actingAsUserId, isActive])
}

// ─── Invitations ─────────────────────────────────────────────────────────────

enum UserInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model UserInvitation {
  id         String               @id @default(cuid())
  token      String               @unique @default(cuid())
  email      String
  roleNames  Json                 @default("[]")
  status     UserInvitationStatus @default(PENDING)
  note       String?
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  invitedById String
  invitedBy   User   @relation("InvitationSentBy", fields: [invitedById], references: [id], onDelete: Cascade)

  acceptedByUserId String? @unique
  acceptedBy       User?   @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
  @@index([expiresAt])
}
